{
  "name": "BrandFlow - AI Process",
  "active": false,
  "nodes": [
    {
      "parameters": {
        "path": "brandflow-ai-process",
        "method": "POST",
        "responseMode": "responseNode"
      },
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body;\n\nreturn [{\n  json: {\n    contentId: body.contentId,\n    userId: body.userId,\n    operation: body.operation || 'full',\n    platform: body.platform || 'instagram_feed',\n    originalUrl: body.originalUrl\n  }\n}];"
      },
      "id": "parse-input",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "={{ $vars.CARVEKIT_URL }}/remove-background",
        "requestMethod": "POST",
        "responseFormat": "json",
        "jsonParameters": true,
        "bodyParametersJson": "={\n  \"image_url\": \"{{ $json.originalUrl }}\"\n}",
        "options": {}
      },
      "id": "bg-remove",
      "name": "Background Remove",
      "type": "n8n-nodes-base.httpRequest",
      "position": [480, 300]
    },
    {
      "parameters": {
        "url": "={{ $vars.BACKEND_API_URL }}/api/contents/{{ $json.contentId }}/process",
        "requestMethod": "POST",
        "responseFormat": "json",
        "jsonParameters": true,
        "bodyParametersJson": "={\n  \"step\": \"bg_removed\",\n  \"processed_url\": \"{{ $json.processed_url }}\"\n}",
        "options": {}
      },
      "id": "update-content",
      "name": "Update Content",
      "type": "n8n-nodes-base.httpRequest",
      "position": [720, 300]
    },
    {
      "parameters": {
        "respondWith": {},
        "respondWithSuccess": true,
        "responseBody": {
          "success": true,
          "message": "AI process started",
          "contentId": "{{ $json.contentId }}"
        }
      },
      "id": "respond",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondtowebhook",
      "position": [960, 300]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          {
            "node": "Parse Input",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Input": {
      "main": [
        [
          {
            "node": "Background Remove",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Background Remove": {
      "main": [
        [
          {
            "node": "Update Content",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Update Content": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": ["ai", "process", "background-removal"],
  "meta": {
    "templateCredsSetupComplete": false
  }
}